# ==== Supabase ====
# Project Settings -> API in your Supabase dashboard
# The browser never talks to Supabase directly in this project - only
# server-side API routes do, using the service role key below. So only
# ONE pair of values is needed, and neither is exposed to the browser.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional - only needed if the dashboard and API are deployed separately.
# Leave empty if both live in this same Vercel project (default setup).
NEXT_PUBLIC_API_BASE=
