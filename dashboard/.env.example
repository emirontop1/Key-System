# ==== Supabase ====
# Project Settings -> API in your Supabase dashboard

# Public - safe to expose in the browser (used by the dashboard UI)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Secret - server-side only, NEVER exposed to the browser.
# Used by /pages/api/* to bypass RLS safely inside serverless functions.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional - only needed if the dashboard and API are deployed separately.
# Leave empty if both live in this same Vercel project (default setup).
NEXT_PUBLIC_API_BASE=
